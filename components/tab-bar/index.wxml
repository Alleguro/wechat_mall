<!--components/tab-bar/index.wxml-->
<view class="container">
    <!--左边两个icon-->
    <view class="icons">
        <view bind:tap="onGoToHome">
            <l-icon size="46" name="home" l-class="sleeve"></l-icon>
            <text>首页</text>
        </view>
        <view bind:tap="onGoToCart">
            <l-badge value="777" max-count="99" number-type="limit">
                <l-icon size="46" name="cart" color="#157668"/>
            </l-badge>
            <text>购物车</text>
        </view>
    </view>
    <!--右边两个按钮-->
    <view bind:tap="onAddToCart" class="cart btn-font">
        <text>加入购物车</text>
    </view>
    <view bind:tap="onBuy" class="buy btn-font">
        <text>立即购买</text>
    </view>
</view>
