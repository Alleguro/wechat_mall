/* components/tab-bar/index.wxss */

/*这个类的名字可以任意自定义 "首页"icon样式*/
.sleeve {
    font-family: sleeve !important;
    color: #157658 !important;
}

.container {
    height: 100rpx;
    width: 100%;
    display: flex;
    flex-direction: row;
    background: #fff;
}
/*加入购物车盒立即购买区域*/
.btn-font {
    color: #fff;
    font-size: 32rpx;
    display: flex;
    /*flex: 1;*/
    flex-direction: row;
    justify-content: center;
    align-items: center;
}
/*立即购买按钮*/
.buy {

    background: #157658;
    width: 260rpx;
    height: 100%;
}
/*加入购物车按钮*/
.cart {
    background: #333;
    width: 260rpx;
    height: 100%;
}
.icons {
    box-sizing: border-box;
    padding-left: 16rpx;
    padding-right: 26rpx;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-around;
    width: 250rpx;
    height: 100%;
    color: #999;
    /*background: coral;*/
}
.icons > view {
    width: 50%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}
.icons > view:nth-child(2) {
    padding-top: 8rpx;
}
.icons text {
    font-size: 20rpx;
}