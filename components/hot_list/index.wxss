/* components/hot_list/index.wxss */
.container {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding-top: 40rpx;
    background: #fff;
}

.title {
    width: 690rpx;
    height: 90rpx;
    display: flex;
}

.inner-container {
    width: 100%;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
}

.left {
    display: flex;
    width: 346rpx;
    height: 522rpx;
}

.right-container {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.right-size {
    width: 400rpx;
    height: 260rpx;
    display: flex;
}