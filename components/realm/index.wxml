<view class="container">
    <view class="sku-preview">
        <image class="sku-img" src=""></image>
        <view class="sku-description">
            <text class="title">测试sku</text>
            <view>
                <view class="price-row">
                    <l-price value="777" color="#157658" value-size="28" unit-size="20" autofix></l-price>
                    <l-price value="999" color="#999" value-size="26" l-class="discount-price" deleted></l-price>
                </view>
                <view class="sku-pending">
                    <text>请选择：</text>
                </view>
            </view>
        </view>
    </view>
    <!--    横线-->
    <view class="hr"></view>
    <block wx:for="{{fences}}" wx:key="index">
        <s-fence bind:cellTap="onCellTap" x="{{index}}" fence="{{item}}"></s-fence>
    </block>
</view>