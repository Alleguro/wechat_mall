<!-- 引入价格原价和折扣价筛选方法 -->
<wxs src="../../wxs/price.wxs" module="p"></wxs>
<view class="container">
    <view class="sku-preview">
        <image class="sku-img" src="{{previewImg}}"></image>
        <view class="sku-description">
            <text class="title">{{title}}</text>
            <view>
                <view class="price-row">
                    <!--                    <l-price wx:if="{{p.mainPrice(price,discountPrice).display}}"-->
                    <!--                             color="#157658" value-size="28" unit-size="20" autofix-->
                    <!--                             value="{{p.mainPrice(price,discountPrice).price}}">-->
                    <!--                    </l-price>-->
                    <!--                    <l-price wx:if="{{p.slashedPrice(price,discountPrice).display}}"-->
                    <!--                             color="#999" size="26" l-class="discount-price" deleted-->
                    <!--                             value="{{p.slashedPrice(price,discountPrice).price}}">-->
                    <!--                    </l-price>-->

                    <l-price value="{{discountPrice?discountPrice:price}}" color="#157658" value-size="28"
                             unit-size="20" autofix></l-price>
                    <l-price wx:if="{{discountPrice}}" value="{{price}}" color="#999" value-size="26"
                             l-class="discount-price"
                             deleted></l-price>
                </view>
                <view class="sku-pending">
                    <text>请选择：</text>
                </view>
            </view>
        </view>
    </view>
    <!--    横线-->
    <view class="hr"></view>
    <block wx:for="{{fences}}" wx:key="index">
        <s-fence bind:cellTap="onCellTap" x="{{index}}" fence="{{item}}"></s-fence>
    </block>
</view>