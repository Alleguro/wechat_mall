/* components/spu-scroll/index.wxss */
.container {
    padding: 42rpx 0 34rpx 28rpx;
    background: #fff;
    margin-bottom: 20rpx;
}

.title {
    width: 694rpx;
    height: 90rpx;
}

.scroll-view {
    margin-top: 20rpx;
    display: flex;
    /* 解决底部留白问题 */
    align-items: center;
}

/* 单位 */
.price-unit {
    font-size: 24rpx !important;
}

/* 值 */
.price-value {
    font-size: 26rpx !important;
}

.spu-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-right: 60rpx;
}

.spu-text {
    line-height: 20rpx;
    font-size: 20rpx;
    color: #666;
}

.spu-img {
    width: 160rpx;
    height: 160rpx;
}