/* components/sale-explain/index.wxss */
.container {
    box-sizing: border-box;
    width: 710rpx;
    border: 2rpx dashed #dcebe6;
    display: flex;
    flex-direction: column;
    padding: 5rpx 25rpx;
    background-color: #fff;
}

.inner {
    height: 50rpx;
    border-bottom: 2rpx solid #dcebe6;
    display: flex;
    flex-direction: column;
    justify-content: center;
    font-size: 24rpx;
    color: #333;
}

/*伪类实现制表符*/
.inner text:before {
    content: '·';
    margin-right: 26rpx;
}

/*取消最后一个的边框*/
.container > .inner:last-child {
    border: none;
}