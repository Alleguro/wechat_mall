/* pages/detail/detail.wxss */

/*A位商品轮播图*/
.top {
    width: 100%;
    height: 680rpx;
}

/*C位 发货参数*/
.sku-pending {
    box-sizing: border-box;
    width: 100%;
    height: 80rpx;
    background-color: #fff;
    margin: 10rpx 0;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    font-size: 28rpx;
    color: #333;
    padding: 0 30rpx;
}

.specs > text:first-child {
    color: #999;
    font-size: 24rpx;
}

.specs > text:nth-child(2) {
    font-size: 24rpx;
    color: #157658;
}

/*D位商品描述*/
.explain {
    margin-top: 10rpx;
    background: #fff;
    padding-bottom: 20rpx;
    padding-top: 20rpx;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
}

/*E位商品详情图区域*/
/*.detail-img-container {*/
/*    margin-bottom: 200rpx;*/
/*}*/

/*E位商品详情图*/
.detail-img {
    display: flex;
    width: 100%;
}

/*底部栏*/
.tabbar {
    position: fixed;
    bottom: 0;
}