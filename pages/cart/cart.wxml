<!--pages/cart/cart.wxml-->
<view wx:if="{{!isEmpty}}">
    <block wx:for="{{cartItems}}">
        <s-cart-item bind:overflow="onOverflow"
                     bind:itemdelete="onDeleteItem">
        </s-cart-item>
    </block>
</view>

        <!--cartItem没数据时所提示的内容-->
<view class="empty-container" wx:if="{{isEmpty}}">
    <s-empty show-btn
             show
             text="购物车空空的，去逛逛吧"
             btn-text="去逛逛">
    </s-empty>
</view>